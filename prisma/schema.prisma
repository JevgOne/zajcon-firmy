// Prisma schema for Zajcon Firmy
// Marketplace pro prodej a výkup s.r.o.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ==================== FIRMY ====================

model Firma {
  id              String      @id @default(cuid())

  // Základní údaje (z ARES)
  ico             String      @unique
  nazev           String
  datumZalozeni   DateTime

  // Adresa
  sidloUlice      String
  sidloMesto      String
  sidloPsc        String

  // Detaily
  zakladniKapital Int         @default(1000)
  predmetPodnikani String[]   @default([])

  // Vlastnosti
  platceDph       Boolean     @default(false)
  datovaSchranka  Boolean     @default(true)
  historieObratu  Boolean     @default(false)

  // Prodej
  cena            Int
  cenaDohodnout   Boolean     @default(false)
  status          FirmaStatus @default(VOLNA)
  featured        Boolean     @default(false)
  tags            String[]    @default([])
  popis           String?

  // SEO
  slug            String      @unique
  metaTitle       String?
  metaDescription String?

  // Admin
  poznamkyInterni String?
  published       Boolean     @default(false)
  createdAt       DateTime    @default(now())
  updatedAt       DateTime    @updatedAt

  poptavky        Poptavka[]

  @@index([status, published])
  @@index([datumZalozeni])
  @@index([cena])
}

enum FirmaStatus {
  VOLNA
  REZERVOVANA
  PRODANA
  STAZENA
}

// ==================== POPTÁVKY ====================

model Poptavka {
  id              String          @id @default(cuid())
  typ             PoptavkaTyp

  // Kontakt
  email           String
  telefon         String?
  jmeno           String?

  // Pro výkup (prodej firmy nám)
  icoVykup        String?
  poznamkaVykup   String?

  // Pro nákup (koupě od nás)
  firmaId         String?
  firma           Firma?          @relation(fields: [firmaId], references: [id], onDelete: SetNull)
  zpravaNakup     String?

  // Tracking
  utmSource       String?
  utmMedium       String?
  utmCampaign     String?

  // Status
  status          PoptavkaStatus  @default(NOVA)
  poznamkyInterni String?
  assignedTo      String?

  createdAt       DateTime        @default(now())
  updatedAt       DateTime        @updatedAt

  @@index([status, typ])
  @@index([createdAt])
}

enum PoptavkaTyp {
  VYKUP
  NAKUP
  DOTAZ
}

enum PoptavkaStatus {
  NOVA
  KONTAKTOVANO
  JEDNANI
  DOKONCENO
  ZAMITNUTO
}

// ==================== ADMIN ====================

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  passwordHash  String
  role          UserRole  @default(EDITOR)

  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

enum UserRole {
  ADMIN
  EDITOR
}

// ==================== NASTAVENÍ ====================

model Settings {
  id            String   @id @default("global")

  telefon       String   @default("+420 123 456 789")
  email         String   @default("firmy@zajcon.cz")
  adresa        String   @default("Praha, Česká republika")

  heroTitle     String   @default("Hotové firmy k okamžitému převzetí")
  heroSubtitle  String   @default("Prověřené společnosti s čistou historií.")

  updatedAt     DateTime @updatedAt
}
